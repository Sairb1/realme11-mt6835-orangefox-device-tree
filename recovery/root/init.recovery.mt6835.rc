import /tee.rc
import /trustonic.rc

on early-init
    # Bind mount our AOSP 12.1 compatible VINTF manifest over the stock A15 manifest
    # to prevent libvintf from choking on version 5.0 and crashing keystore2
    mount none /system/etc/manifest.xml /vendor/etc/vintf/manifest.xml bind

on init
    setprop sys.usb.configfs 1
    setprop sys.usb.controller "11201000.usb0"
    setprop sys.usb.ffs.aio_compat 1
    export LD_LIBRARY_PATH /vendor/lib64:/vendor/lib:/system/lib64:/system/lib:/sbin
    mkdir /mnt/vendor/persist/mcRegistry
    mkdir /mnt/vendor/persist
    mount ext4 /dev/block/by-name/persist /mnt/vendor/persist rw
    setprop crypto.ready 1

on fs
    install_keyring

# We need vold early for metadata encryption
on early-fs
    start vold

on late-fs
    # NOTE: exec_start wait_for_keymaster is intentionally removed for A15.
    # In A15, KeyMint is AIDL V2. If the service fails to register (ABI issue),
    # exec_start would block init forever causing a dead boot.
    # wait_for_keymaster will still be called implicitly by vold when needed.
    # Re-enable this line ONLY after confirming keymint starts successfully.
    # exec_start wait_for_keymaster

    # Mount RW partitions which need run fsck
    # mount_all /first_stage_ramdisk/fstab.mt6835 --late

on fs
    wait /dev/block/platform/soc/112b0000.ufshci
    symlink /dev/block/platform/soc/112b0000.ufshci /dev/block/bootdevice

on post-fs
    start boot-hal-1-2

    # Support A/B feature for EMMC and UFS boot region
    symlink /dev/block/sda /dev/block/mmcblk0boot0
    symlink /dev/block/sdb /dev/block/mmcblk0boot1
    symlink /dev/block/mmcblk0boot0 /dev/block/by-name/preloader_a
    symlink /dev/block/mmcblk0boot1 /dev/block/by-name/preloader_b

    symlink /dev/block/mmcblk0boot0 /dev/block/bootdevice/by-name/preloader_a
    symlink /dev/block/mmcblk0boot1 /dev/block/bootdevice/by-name/preloader_b

    # Support A/B feature for combo emmc and ufs OTA update
    symlink /dev/block/by-name/preloader_a /dev/block/by-name/preloader_emmc_a
    symlink /dev/block/by-name/preloader_b /dev/block/by-name/preloader_emmc_b
    symlink /dev/block/by-name/preloader_a /dev/block/by-name/preloader_ufs_a
    symlink /dev/block/by-name/preloader_b /dev/block/by-name/preloader_ufs_b

    symlink /dev/block/by-name/preloader_a /dev/block/bootdevice/by-name/preloader_emmc_a
    symlink /dev/block/by-name/preloader_b /dev/block/bootdevice/by-name/preloader_emmc_b
    symlink /dev/block/by-name/preloader_a /dev/block/bootdevice/by-name/preloader_ufs_a
    symlink /dev/block/by-name/preloader_b /dev/block/bootdevice/by-name/preloader_ufs_b

    exec u:r:update_engine:s0 root root -- /system/bin/mtk_plpath_utils

    symlink /dev/block/mapper/pl_a /dev/block/by-name/preloader_raw_a
    symlink /dev/block/mapper/pl_b /dev/block/by-name/preloader_raw_b

    symlink /dev/block/mapper/pl_a /dev/block/bootdevice/by-name/preloader_raw_a
    symlink /dev/block/mapper/pl_b /dev/block/bootdevice/by-name/preloader_raw_b

    start mtk.plpath.utils.link

service mtk.plpath.utils.link /system/bin/mtk_plpath_utils
    class main
    user root
    group root system
    disabled
    oneshot
    seclabel u:r:recovery:s0

service wait_for_keymaster /system/bin/wait_for_keymaster
    user root
    group root system
    priority -20
    ioprio rt 0
    seclabel u:r:recovery:s0

service vendor.gatekeeper-1-0 /system/bin/android.hardware.gatekeeper@1.0-service
    interface android.hardware.gatekeeper@1.0::IGatekeeper default
    user root
    group root
    disabled
    seclabel u:r:recovery:s0

service vendor.keymint-trustonic /system/bin/android.hardware.security.keymint-service.trustonic
    class early_hal
    user root
    group root system
    seclabel u:r:recovery:s0

on property:crypto.ready=1
    start mobicore
    start vendor.gatekeeper-1-0
    start vendor.keymint-trustonic

on property:hwservicemanager.ready=true
    start mobicore
    start vendor.keymint-trustonic
    start vendor.gatekeeper-1-0

on property:ro.crypto.state=unsupported
    stop mobicore
    stop vendor.keymint-trustonic
    stop vendor.gatekeeper-1-0

on property:ro.crypto.state=unencrypted
    stop mobicore
    stop vendor.keymint-trustonic
    stop vendor.gatekeeper-1-0

on property:twrp.decrypt.done=true
    stop mobicore
    stop vendor.keymint-trustonic
    stop vendor.gatekeeper-1-0

on property:crypto.ready=0
    stop mobicore
    stop vendor.keymint-trustonic
    stop vendor.gatekeeper-1-0

on boot
    chmod 0755 /system/bin/cpu_temp.sh
    start cpu_temp_loop
    start health-hal-2-1
    setprop sys.usb.config adb

    # Set CPU scaling governor to performance on boot to resolve UI rendering lag
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor performance
    write /sys/devices/system/cpu/cpu6/cpufreq/scaling_governor performance

    # Enable high touch report rate (120Hz/240Hz) if supported by the panel
    write /proc/touchpanel/game_switch_enable 1
    write /proc/touchpanel/oplus_tp_limit_enable 0

service vendor.oplus.vibrator-default /system/bin/vendor.oplus.hardware.vibrator-service
    class hal
    user root
    group root system
    setenv RICHTAP_DEVICE_PATH /dev/awinic_haptic
    setenv ENV_RICHTAP_CONFIG_PATH /odm/etc/aac_richtap.config
    seclabel u:r:recovery:s0
    disabled

service cpu_temp_loop /system/bin/cpu_temp.sh
    class main
    user root
    group root
    seclabel u:r:recovery:s0
